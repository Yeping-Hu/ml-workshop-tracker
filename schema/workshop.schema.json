{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workshop.schema.json",
  "title": "Workshop edition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "conference",
    "year",
    "topics"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "description": "Full official workshop name."
    },
    "acronym": {
      "type": "string",
      "maxLength": 40,
      "description": "Short name (e.g. 'MATH-AI'). Empty string if none."
    },
    "conference": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Conference id; must exist in data/conferences.yml."
    },
    "year": {
      "type": "integer",
      "minimum": 2014,
      "maximum": 2100
    },
    "website": {
      "type": "string",
      "pattern": "^https?://",
      "maxLength": 500,
      "description": "Official workshop website. Leave unset if unknown \u2014 the site shows a \"help us add it\" prompt."
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "description": "Topic ids; each must exist in data/topics.yml."
    },
    "submission_deadline": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}( \\d{2}:\\d{2})?$",
      "description": "'YYYY-MM-DD' or 'YYYY-MM-DD HH:MM' (wall-clock time in `timezone`)."
    },
    "timezone": {
      "type": "string",
      "maxLength": 50,
      "description": "'AoE' (default), 'UTC', or an IANA name like 'America/Los_Angeles'."
    },
    "deadline_notes": {
      "type": "string",
      "maxLength": 300
    },
    "notification_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "workshop_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "openreview_venue_id": {
      "type": "string",
      "maxLength": 200,
      "description": "e.g. 'NeurIPS.cc/2024/Workshop/MATH-AI'. Enables the auto paper list."
    },
    "proceedings_url": {
      "type": "string",
      "pattern": "^https?://",
      "maxLength": 500
    },
    "submission_portal": {
      "type": "string",
      "enum": [
        "openreview",
        "cmt",
        "email",
        "other",
        "unknown"
      ]
    },
    "organizers": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "string",
        "maxLength": 120
      }
    },
    "previous_editions": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "year"
        ],
        "properties": {
          "year": {
            "type": "integer",
            "minimum": 2000,
            "maximum": 2100
          },
          "website": {
            "type": "string",
            "pattern": "^https?://"
          },
          "proceedings_url": {
            "type": "string",
            "pattern": "^https?://"
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 1000
    },
    "added": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date this entry was added (used for the 'new workshops' RSS feed)."
    }
  }
}