---
import Base from '../components/Base.astro';
import WorkshopRow from '../components/WorkshopRow.astro';
import {
  workshops,
  upcomingWithDeadline,
  upcomingTba,
  deadlinePassed,
  conferences,
  topics,
  paperCount,
  proposalCalls,
  conferenceById,
} from '../lib/data';
import { href, REPO_URL } from '../lib/site';

// Topics that actually appear on boardable (upcoming or recent passed) rows.
const boardRows = [...upcomingWithDeadline, ...upcomingTba, ...deadlinePassed];
const activeTopicIds = new Set(boardRows.flatMap((w) => w.topics ?? []));
const boardTopics = topics.filter((t) => activeTopicIds.has(t.id));

// Between cycles (no upcoming deadlines), show the current cycle's passed
// deadlines by default so the board is never misleadingly empty.
const defaultShowPassed = upcomingWithDeadline.length === 0 && deadlinePassed.length > 0;
---

<Base>
  <section class="masthead">
    <p class="eyebrow">{conferences.map((c) => c.name).join(" · ")} workshops</p>
    <h1>Every workshop deadline, one board.</h1>
    <p class="lede">
      Submission deadlines for conference workshops across machine learning and robotics, resolved from AoE to your local
      time — plus links to past editions and their accepted papers. Community-maintained,
      so always confirm on the official workshop page.
    </p>
    <div class="statline">
      <span><strong>{upcomingWithDeadline.length}</strong> open calls</span>
      <span><strong>{workshops.length}</strong> workshop editions tracked</span>
      <span><strong>{paperCount.toLocaleString('en-US')}</strong> papers indexed</span>
    </div>
    <p class="nextline" id="next-deadline" aria-live="off">Next deadline: …</p>
  </section>

  <div class="filterbar" role="search">
    <div class="kw-box" onclick="document.getElementById('q')?.focus()">
      <span id="kwChips"></span>
      <input id="q" type="search" placeholder="Filter… (Enter adds a keyword)" aria-label="Filter workshops by keywords" />
    </div>
    <div class="f-group" aria-label="Conference filter">
      {conferences.map((c) => (
        <label class="check">
          <input type="checkbox" class="f-conf" value={c.id} />
          <span class="conf-dot" style={`--conf:${c.color}`}></span>
          {c.name}
        </label>
      ))}
    </div>
    <details class="dd">
      <summary id="topicSummary">Topics</summary>
      <div class="dd-panel">
        {boardTopics.map((t) => (
          <label class="check">
            <input type="checkbox" class="f-topic" value={t.id} />
            {t.label}
          </label>
        ))}
      </div>
    </details>
    <label class="check">
      <input type="checkbox" id="showPassed" checked={defaultShowPassed} data-default={defaultShowPassed ? '1' : '0'} />
      Show passed deadlines
    </label>
    <button class="btn-quiet" id="clearFilters" type="button">Clear</button>
    <span class="resultcount" id="resultCount"></span>
  </div>

  <section class="board" aria-label="Workshop deadlines">
    {upcomingWithDeadline.map((w) => <WorkshopRow w={w} />)}
    {deadlinePassed.map((w) => <WorkshopRow w={w} passed startVisible={defaultShowPassed} />)}
    <div class="empty-state" id="emptyState" hidden>
      <p>No workshops match these filters.</p>
      <p class="small">
        Try clearing filters — or
        <a href={`${REPO_URL}/issues/new?template=add-workshop.yml`}>add a missing workshop</a>.
      </p>
    </div>
  </section>

  {upcomingTba.length > 0 && (
    <details class="tba-section">
      <summary>
        {upcomingTba.length} more {upcomingTba.length === 1 ? 'workshop' : 'workshops'} announced
        without a listed deadline yet — help add them
      </summary>
      {upcomingTba.map((w) => {
        const conf = conferenceById.get(w.conference);
        return (
          <div class="arch-row" data-ws-row data-conf={w.conference} data-status={w.status} data-topics={(w.topics ?? []).join(' ')} data-search={[w.name, w.acronym, conf?.name, w.year].filter(Boolean).join(' ').toLowerCase()}>
            <span class="ws-name"><a href={href(`/workshop/${w.slug}/`)}>{w.name}</a></span>
            <span class="muted small">{conf?.name} {w.year}</span>
            <span class="links">
              {w.website && <a href={w.website} rel="noopener">Site ↗</a>}
              <a class="link-tba" href={`${REPO_URL}/edit/main/data/workshops/${w.slug}.yml`} rel="noopener">✎ add deadline</a>
            </span>
          </div>
        );
      })}
    </details>
  )}

  {proposalCalls.length > 0 && (
    <section>
      <h2>Organizing a workshop? Proposal deadlines</h2>
      <p class="muted small">
        When organizers can apply to host a workshop at each conference. Once a list of accepted
        workshops is announced, the tracker imports them automatically from OpenReview.
      </p>
      <ul class="proposal-list">
        {proposalCalls.map((c) => {
          const conf = conferenceById.get(c.conference);
          return (
            <li>
              <span class="badge" style={`--conf:${conf?.color ?? '#888'}; padding: 0.28rem 0.7rem;`}>{conf?.name} {c.year}</span>
              <span class="mono">{c.deadlineWallClock}</span>
              {c.open ? (
                <span class="countdown" data-deadline-ms={c.deadlineUtcMs} data-name={`${conf?.name} ${c.year} workshop proposals`}>—</span>
              ) : (
                <span class="pill deadline_passed">Closed</span>
              )}
              <a href={c.url} rel="noopener">Call for proposals ↗</a>
              {c.notes && <span class="muted small" style="flex-basis: 100%;">{c.notes}</span>}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  <aside class="cta">
    <p>
      <strong>Missing a workshop?</strong> Add it in about two minutes — fill in the form
      and a pull request is opened automatically.
    </p>
    <span>
      <a class="btn" href={`${REPO_URL}/issues/new?template=add-workshop.yml`}>Add a workshop</a>
    </span>
  </aside>

  <script src="../scripts/board.js"></script>
</Base>
