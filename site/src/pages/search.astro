---
import Base from '../components/Base.astro';
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
---

<Base title="Search" description="Search workshops and accepted papers across AI and robotics conference workshops.">
  <section class="masthead">
    <p class="eyebrow">Workshops & papers</p>
    <h1>Search</h1>
    <p class="lede">
      Full-text search across every tracked workshop and all cached accepted-paper titles and
      authors. Add several keywords — results must match all of them. Runs entirely in your browser.
    </p>
  </section>

  <div class="filterbar" role="search">
    <div class="kw-box" onclick="document.getElementById('q')?.focus()">
      <span id="kwChips"></span>
      <input id="q" type="search" placeholder="Search… (Enter adds a keyword)" aria-label="Search workshops and papers by keywords" autofocus />
    </div>
    <span class="resultcount" id="resultCount"></span>
  </div>

  <ol class="pf-results" id="results"></ol>
  <p class="muted" id="searchHint">
    Try keywords like a method, an author name, or a topic — e.g. <em>diffusion</em> + <em>robotics</em>.
  </p>
  <noscript><p class="muted">Search requires JavaScript.</p></noscript>
  <p class="muted small" style="margin-top:2.5rem">
    Powered by a static <a href="https://pagefind.app" rel="noopener">Pagefind</a> index built at
    deploy time — no server involved. (In local <code>astro dev</code> the index doesn't exist yet;
    run a full build to test search.)
  </p>

  <script is:inline define:vars={{ base }}>
    const $ = (s) => document.querySelector(s);
    const input = $('#q');
    const chipsBox = $('#kwChips');
    const resultsEl = $('#results');
    const countEl = $('#resultCount');
    const hintEl = $('#searchHint');
    let keywords = [];
    let pagefind = null;
    let loadError = false;

    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]);

    function renderChips() {
      chipsBox.innerHTML = keywords
        .map(
          (k, i) =>
            `<span class="kw-chip">${esc(k)}<button type="button" class="kw-x" data-i="${i}" aria-label="Remove keyword ${esc(k)}">×</button></span>`,
        )
        .join('');
    }

    function syncUrl() {
      const p = new URLSearchParams();
      if (keywords.length) p.set('q', keywords.join(','));
      history.replaceState(null, '', p.toString() ? `?${p}` : location.pathname);
    }

    async function ensurePagefind() {
      if (pagefind || loadError) return pagefind;
      try {
        pagefind = await import(`${base}/pagefind/pagefind.js`);
        await pagefind.options({ baseUrl: `${base}/` });
        await pagefind.init();
      } catch (err) {
        loadError = true;
        countEl.textContent = '';
        hintEl.hidden = false;
        hintEl.textContent =
          "Search couldn't load: " + (err?.message || err) +
          ' (in local dev the index only exists after a full build).';
      }
      return pagefind;
    }

    async function runSearch() {
      const terms = [...keywords, input.value.trim()].filter(Boolean);
      if (terms.length === 0) {
        resultsEl.innerHTML = '';
        countEl.textContent = '';
        hintEl.hidden = false;
        return;
      }
      const pf = await ensurePagefind();
      if (!pf) return;
      const search = await pf.debouncedSearch(terms.join(' '), {}, 250);
      if (search === null) return; // superseded by newer keystroke
      hintEl.hidden = true;
      const top = search.results.slice(0, 30);
      const data = await Promise.all(top.map((r) => r.data()));
      countEl.textContent = `${search.results.length} result${search.results.length === 1 ? '' : 's'}`;
      resultsEl.innerHTML = data
        .map(
          (d) => `
        <li class="pf-result">
          <a class="pf-title" href="${esc(d.url)}">${esc(d.meta?.title ?? d.url)}</a>
          <p class="pf-excerpt">${d.excerpt}</p>
        </li>`,
        )
        .join('');
      if (search.results.length === 0) {
        resultsEl.innerHTML = '<li class="muted">No matches — try removing a keyword.</li>';
      }
    }

    input.addEventListener('input', runSearch);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        const v = input.value.trim().toLowerCase();
        if (v && !keywords.includes(v)) keywords.push(v);
        input.value = '';
        renderChips();
        syncUrl();
        runSearch();
      } else if (e.key === 'Backspace' && input.value === '' && keywords.length) {
        keywords.pop();
        renderChips();
        syncUrl();
        runSearch();
      }
    });
    chipsBox.addEventListener('click', (e) => {
      const btn = e.target.closest('.kw-x');
      if (!btn) return;
      keywords.splice(Number(btn.dataset.i), 1);
      renderChips();
      syncUrl();
      runSearch();
      input.focus();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && !/^(INPUT|TEXTAREA|SELECT)$/.test(document.activeElement?.tagName || '')) {
        e.preventDefault();
        input.focus();
      }
    });

    // hydrate from URL
    keywords = (new URLSearchParams(location.search).get('q') || '')
      .split(',')
      .map((s) => s.trim().toLowerCase())
      .filter(Boolean);
    renderChips();
    if (keywords.length) runSearch();
  </script>
</Base>
