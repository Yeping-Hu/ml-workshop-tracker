---
import Base from '../components/Base.astro';
import { href, CALENDAR_ENABLED } from '../lib/site';
---

<Base title="Calendar feeds" description="Calendar subscriptions are temporarily paused.">
  <Fragment slot="head"></Fragment>
  <meta name="robots" content="noindex" />
  <section class="masthead">
    <p class="eyebrow">Temporarily paused</p>
    <h1>Calendar feeds are paused</h1>
    <p class="lede">
      We're verifying imported workshop dates before offering calendar subscriptions again —
      a wrong deadline in your calendar is worse than no calendar at all. If you subscribed
      earlier, the feed now publishes zero events, so stale entries clear out on your app's
      next refresh.
    </p>
    <p class="lede">
      Meanwhile, the <a href={href('/')}>deadline board</a> always shows current dates with
      live countdowns, and you can follow new additions via <a href={href('/rss.xml')}>RSS</a>.
    </p>
  </section>
</Base>
