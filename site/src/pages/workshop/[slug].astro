---
import Base from '../../components/Base.astro';
import { workshops, conferenceById, topicById, loadPaperCache } from '../../lib/data';
import { href, REPO_URL, CALENDAR_ENABLED } from '../../lib/site';

export function getStaticPaths() {
  return workshops.map((w) => ({ params: { slug: w.slug }, props: { w } }));
}

const { w } = Astro.props;
const conf = conferenceById.get(w.conference) ?? { name: w.conference, color: '#888' };
const cache = loadPaperCache(w.slug);
const statusLabel = w.statusLabel;
const isSeed = (w.notes || '').includes('SEED DATA');
const portalLabel: Record<string, string> = {
  openreview: 'OpenReview',
  cmt: 'CMT',
  email: 'Email',
  other: 'Other',
  unknown: 'Unknown',
};
// Stable per-paper id for device-local favorites: the OpenReview forum id
// when present (survives cache refreshes/reordering), else slug+index.
const paperId = (p: any, i: number) =>
  String(p.forum_url || p.pdf_url || '').match(/[?&]id=([^&#]+)/)?.[1] ?? `${w.slug}~${i}`;
// How a saved paper is labeled/grouped on the /saved/ page.
const wsLabel = `${w.acronym || w.name} — ${conf.name} ${w.year}`;
// Browse-mode sort key (used only when the search box is empty — keyword
// queries keep Pagefind's relevance order). Lexicographic ascending over
// '<band>-<14-digit ms>': 0 open calls by soonest deadline, 1 upcoming TBA
// by soonest event, 2 call closed but event upcoming by soonest event,
// 3 past by most recent first (inverted).
const searchOrder = (() => {
  const pad = (ms: number) => String(Math.max(0, Math.min(ms, 99999999999999))).padStart(14, '0');
  const MAX = 99999999999999;
  const ev = w.workshopDateUtcMs ?? w.deadlineUtcMs ?? MAX;
  if (w.status === 'upcoming' && w.deadlineUtcMs != null) return '0-' + pad(w.deadlineUtcMs);
  if (w.status === 'upcoming') return '1-' + pad(ev);
  if (w.status === 'deadline_passed') return '2-' + pad(ev);
  return '3-' + pad(MAX - (w.workshopDateUtcMs ?? w.deadlineUtcMs ?? 0));
})();

---

<Base title={`${w.acronym || w.name} (${conf.name} ${w.year})`} description={`${w.name} — ${conf.name} ${w.year}: deadline, dates, and accepted papers.`}>
  <article>
   <div
    data-pf-ws
    data-conf={conf.name}
    data-year={String(w.year)}
    data-wstatus={statusLabel}
    data-type="Workshops"
    data-dl={w.deadlineWallClock ?? ''}
    data-pagefind-meta="conference[data-conf], year[data-year], status[data-wstatus], deadline[data-dl]"
    data-pagefind-filter="conference[data-conf], year[data-year], status[data-wstatus], type[data-type]"
   >
    {/* Browse-order sort key: must live on a child — pagefind ignores
        data-pagefind-sort on the --root-selector element itself. */}
    <span data-pagefind-sort="order[data-order]" data-order={searchOrder} hidden></span>
    <header class="detail-head">
      <div class="topline">
        <span class="badge" style={`--conf:${conf.color}; padding: 0.28rem 0.7rem;`}>{conf.name} {w.year}</span>
        <span class={`pill ${w.status}`}>{statusLabel}</span>
        {(w.topics ?? []).map((t: string) => <span class="chip" data-pagefind-filter="topic">{topicById.get(t)?.label ?? t}</span>)}
      </div>
      <h1>{w.name}</h1>
      {w.acronym && <p class="muted mono">{w.acronym}</p>}
      <div class="linkrow">
        <button
          class="star-btn star-btn-labeled"
          type="button"
          data-pagefind-ignore
          data-star-ws={w.slug}
          aria-pressed="false"
          aria-label={`Save ${w.name} to your list`}
          title="Save for later (stays in this browser)"
        >☆</button>
        {w.website ? (
          <a href={w.website} rel="noopener">Official website ↗</a>
        ) : (
          <a class="link-tba" href={`${REPO_URL}/edit/main/data/workshops/${w.slug}.yml`} rel="noopener">Website unknown — help us add it</a>
        )}
        {w.openreview_venue_id && (
          <a href={`https://openreview.net/group?id=${w.openreview_venue_id}`} rel="noopener">OpenReview venue ↗</a>
        )}
        {w.proceedings_url && <a href={w.proceedings_url} rel="noopener">Accepted papers ↗</a>}
        {CALENDAR_ENABLED && w.deadlineUtcMs && <a href={href(`/feeds/ws-${w.slug}.ics`)}>Add deadline to calendar (.ics)</a>}
        <a href={`${REPO_URL}/edit/main/data/workshops/${w.slug}.yml`} rel="noopener">✎ Edit this entry</a>
      </div>
      {isSeed && (
        <p class="seednote">
          <strong>Unverified seed entry.</strong> Some fields are estimates — confirm everything on the
          official website before planning a submission.
        </p>
      )}
    </header>

    <dl class="kv">
      <dt>Submission deadline</dt>
      <dd>
        {w.deadlineWallClock ? (
          <>
            <span class="mono">{w.deadlineWallClock}</span>
            <div class="muted small js-local" data-iso={w.deadlineIso}></div>
            {w.status === 'upcoming' && (
              <div>
                <span class="countdown" data-deadline-ms={w.deadlineUtcMs} data-name={w.acronym || w.name}>—</span>
              </div>
            )}
            {w.deadline_notes && <div class="small" style="color: var(--warn)">{w.deadline_notes}</div>}
          </>
        ) : (
          <>
            TBA — <a class="link-tba" href={`${REPO_URL}/edit/main/data/workshops/${w.slug}.yml`} rel="noopener">know
            the deadline? Add it in one line</a>
            <div class="muted small">The file opens with a ready-to-fill template — takes about a minute.</div>
          </>
        )}
      </dd>
      {w.notification_date && (
        <>
          <dt>Notification</dt>
          <dd>{w.notificationDateLabel}</dd>
        </>
      )}
      {w.workshop_date && (
        <>
          <dt>Workshop day</dt>
          <dd>{w.workshopDateLabel}</dd>
        </>
      )}
      {w.submission_portal && (
        <>
          <dt>Submission portal</dt>
          <dd>{portalLabel[w.submission_portal] ?? w.submission_portal}</dd>
        </>
      )}
      {w.organizers?.length > 0 && (
        <>
          <dt>Organizers</dt>
          <dd>{w.organizers.join(', ')}</dd>
        </>
      )}
      {w.notes && (
        <>
          <dt>Notes</dt>
          <dd class="muted">{w.notes}</dd>
        </>
      )}
    </dl>

    {w.previous_editions?.length > 0 && (
      <section>
        <h2>Previous editions</h2>
        <ul>
          {w.previous_editions.map((p: any) => (
            <li>
              {p.year} — {p.website && <a href={p.website} rel="noopener">website ↗</a>}{' '}
              {p.proceedings_url && <a href={p.proceedings_url} rel="noopener">papers ↗</a>}
            </li>
          ))}
        </ul>
      </section>
    )}

   </div>
    {cache && cache.papers?.length > 0 && (
      <section
        data-pf-papers
        data-conf={conf.name}
        data-year={String(w.year)}
        data-wstatus={statusLabel}
        data-type="Papers"
        data-ptitle={`${w.name} — accepted papers`}
        data-pagefind-meta="title[data-ptitle], conference[data-conf], year[data-year], status[data-wstatus]"
        data-pagefind-filter="conference[data-conf], year[data-year], status[data-wstatus], type[data-type]"
      >
        <h2 id="papers">Accepted papers ({cache.paper_count})</h2>
        <p class="muted small">
          Fetched from OpenReview ({cache.source_api}) on {cache.fetched_at?.slice(0, 10)}.
          {cache.caveat && ` Note: ${cache.caveat}.`}
        </p>
        <ol class="paper-list">
          {cache.papers.map((p: any, i: number) => (
            <li class="paper">
              <h3 class="p-title" id={`p-${paperId(p, i)}`}>
                <button
                  class="star-btn"
                  type="button"
                  data-pagefind-ignore
                  data-star-paper={paperId(p, i)}
                  data-title={p.title}
                  data-pdf={p.pdf_url || ''}
                  data-ws={w.slug}
                  data-wsname={wsLabel}
                  aria-pressed="false"
                  aria-label={`Save paper: ${p.title}`}
                  title="Save for later (stays in this browser)"
                >☆</button>
                {p.forum_url ? <a href={p.forum_url} rel="noopener">{p.title}</a> : p.title}
              </h3>
              <div class="p-authors">
                {(p.authors ?? []).join(', ')}
                {p.pdf_url && (
                  <>
                    {' · '}
                    <a href={p.pdf_url} rel="noopener">PDF</a>
                  </>
                )}
              </div>
              {p.abstract && (
                <details>
                  <summary>Abstract</summary>
                  <p>{p.abstract}</p>
                </details>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}
    {(!cache || !(cache.papers?.length > 0)) && w.openreview_venue_id && (
      <section>
        <h2>Accepted papers</h2>
        <p class="muted">
          Not cached yet — <a href={`https://openreview.net/group?id=${w.openreview_venue_id}`} rel="noopener">browse them on OpenReview ↗</a>.
        </p>
      </section>
    )}
  </article>

  <script src="../../scripts/board.js"></script>
</Base>
