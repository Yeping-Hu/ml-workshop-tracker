---
import { conferenceById, topicById } from '../lib/data';
import { href, REPO_URL } from '../lib/site';

interface Props {
  w: Record<string, any>;
  passed?: boolean; // render as a passed-deadline row (hidden until toggled)
}
const { w, passed = false } = Astro.props;
const conf = conferenceById.get(w.conference) ?? { name: w.conference, color: '#888' };
const search = [w.name, w.acronym, conf.name, w.year].filter(Boolean).join(' ').toLowerCase();
const hasDeadline = w.deadlineUtcMs != null;
---

<div
  class:list={['board-row', { 'row-passed': passed }]}
  data-ws-row
  data-conf={w.conference}
  data-topics={(w.topics ?? []).join(' ')}
  data-status={w.status}
  data-search={search}
  hidden={passed}
>
  <span class="badge" style={`--conf:${conf.color}`}>{conf.name}</span>

  <div class="ws-main">
    <div class="ws-name">
      <a href={href(`/workshop/${w.slug}/`)}>{w.name}</a>
    </div>
    <div class="ws-meta">
      {w.acronym && <span class="mono">{w.acronym}</span>}
      <span>{conf.name} {w.year}</span>
      {(w.topics ?? []).map((t: string) => (
        <span class="chip">{topicById.get(t)?.label ?? t}</span>
      ))}
    </div>
  </div>

  <div class="ws-deadline">
    {hasDeadline ? (
      <>
        <div class="wall">{w.deadlineWallClock}</div>
        <div class="local js-local" data-iso={w.deadlineIso}>resolving your local time…</div>
        {w.deadline_notes && <div class="note">{w.deadline_notes}</div>}
      </>
    ) : (
      <div class="muted">Deadline TBA</div>
    )}
  </div>

  {hasDeadline ? (
    <span class="countdown" data-deadline-ms={w.deadlineUtcMs} data-name={w.acronym || w.name}>—</span>
  ) : (
    <span class="countdown is-tba">TBA</span>
  )}

  <div class="ws-links small">
    <a href={w.website} rel="noopener">Website ↗</a>
    {hasDeadline && <a href={href(`/feeds/ws-${w.slug}.ics`)}>.ics</a>}
    <a href={`${REPO_URL}/edit/main/data/workshops/${w.slug}.yml`} rel="noopener">✎ Edit</a>
  </div>
</div>
