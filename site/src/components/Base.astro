---
import '../styles/global.css';
import { SITE_NAME, SITE_TAGLINE, REPO_URL, CALENDAR_ENABLED, href } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE_TAGLINE } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_NAME}` : `${SITE_NAME} — AI workshop deadlines & papers`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;

const nav = [
  { label: 'Deadlines', path: '/' },
  { label: 'Archive', path: '/archive/' },
  ...(CALENDAR_ENABLED ? [{ label: 'Calendar', path: '/calendar/' }] : []),
  { label: 'Search', path: '/search/' },
  { label: 'About', path: '/about/' },
];
const buildDate = new Date().toISOString().slice(0, 10);
const ogImage = Astro.site ? new URL(href('/og.png'), Astro.site).href : undefined;
const GOATCOUNTER = import.meta.env.PUBLIC_GOATCOUNTER;
const CF_TOKEN = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const current = (p: string) =>
  Astro.url.pathname.replace(/\/+$/, '/') === href(p).replace(/\/+$/, '/') ||
  (p === '/' && Astro.url.pathname === href('/'));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} — new workshops`} href={href('/rss.xml')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {Astro.site && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_NAME,
        url: Astro.site.href,
        potentialAction: {
          '@type': 'SearchAction',
          target: { '@type': 'EntryPoint', urlTemplate: `${Astro.site.href.replace(/\/$/, '')}/search/?q={search_term_string}` },
          'query-input': 'required name=search_term_string',
        },
      })} />
    )}
    <script is:inline>
      // Apply a stored manual theme before first paint (no flash).
      try {
        const t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
      } catch {}
    </script>
    {canonical && <meta property="og:url" content={canonical} />}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="wordmark" href={href('/')}>AI Workshop <span>Tracker</span></a>
        <nav class="site-nav" aria-label="Main">
          {nav.map((n) => (
            <a href={href(n.path)} aria-current={current(n.path) ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
        <button id="themeToggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">◐</button>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div>
          <strong>{SITE_NAME}</strong> — {SITE_TAGLINE} Always confirm details on the official workshop page.
          <span class="mono"> Data refreshed {buildDate}; the site rebuilds automatically every week.</span>
        </div>
        <div>
          Data is community-maintained (CC-BY-4.0) in a public repo ·
          <a href={REPO_URL}> GitHub</a> ·
          <a href={`${REPO_URL}/issues/new?template=add-workshop.yml`}> Add a workshop</a> ·
          <a href={href('/api/workshops.json')}> JSON API</a>
        </div>
      </div>
    </footer>
    {GOATCOUNTER && (
      <script is:inline async data-goatcounter={`https://${GOATCOUNTER}.goatcounter.com/count`} src="https://gc.zgo.at/count.js"></script>
    )}
    {CF_TOKEN && (
      <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${CF_TOKEN}"}`}></script>
    )}
    <script>
      // Open every external link in a new tab.
      for (const a of document.querySelectorAll('a[href^="http"]')) {
        if (a.host !== location.host) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
      }
      // Manual light/dark toggle (falls back to the OS preference until used).
      document.getElementById('themeToggle')?.addEventListener('click', () => {
        const root = document.documentElement;
        const effective =
          root.dataset.theme ||
          (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        const next = effective === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        try { localStorage.setItem('theme', next); } catch {}
      });
    </script>
  </body>
</html>
